{
  "name": "frontend-src",
  "version": "1.0.0",
  "description": "TubeDL in-browser YouTube extraction module",
  "main": "index.js",
  "scripts": {
    "test": "node test/sanity.mjs",
    "build": "esbuild src/app-entry.js --bundle --format=esm --minify --outfile=../frontend/js/app.bundle.js && esbuild node_modules/@ffmpeg/ffmpeg/dist/esm/worker.js --bundle --format=esm --minify --outfile=../frontend/js/ffmpeg-worker.js",
    "build:dev": "esbuild src/app-entry.js --bundle --format=esm --sourcemap --outfile=../frontend/js/app.bundle.js && esbuild node_modules/@ffmpeg/ffmpeg/dist/esm/worker.js --bundle --format=esm --sourcemap --outfile=../frontend/js/ffmpeg-worker.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "bgutils-js": "^4.0.0",
    "googlevideo": "^4.1.1",
    "youtubei.js": "^17.2.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1"
  }
}
